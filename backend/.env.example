API_HOST=127.0.0.1
API_PORT=8000

# Live demo from repo root: npm run demo  (see docs/DEMO.md)
ROOMOS_CONFIG=configs/inference.yaml
ROOMOS_ACTIONS_CONFIG=configs/actions.yaml
ROOMOS_LOG_LEVEL=INFO
ROOMOS_AUTOSTART=1

# Override webcam without editing configs/inference.yaml (run: npm run probe:cameras)
# ROOMOS_VIDEO_SOURCE=0
# ROOMOS_VIDEO_BACKEND=dshow

# --- Supabase (Auth + cloud save) -------------------------------------------
# One-time: npm run supabase:migrate  (needs SUPABASE_DB_PASSWORD below)
# Or paste supabase/migrations/*.sql in the Supabase SQL editor.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_public_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
# SUPABASE_DB_PASSWORD=your_database_password
# HAVEN_REQUIRE_AUTH=true
# HAVEN_ROOM_ID_DEFAULT=default

# Deterministic presentation (no camera/model): npm run demo:replay
# ROOMOS_DEMO_MODE=replay
# ROOMOS_DEMO_FIXTURE=configs/demo_replay.json

# Live devices when room state changes (Preferences → plug / thermostat / lights):
# ROOMOS_ACTIONS_CONFIG=configs/actions.live-devices.yaml

# Direct Kasa plug (legacy overlay; Settings UI preferred):
# ROOMOS_ACTIONS_CONFIG=configs/actions.kasa.yaml
# KASA_PLUG_HOST=192.168.1.50

# Google Nest (Settings → Thermostat → Nest): Device Access + OAuth, not one API key
# NEST_PROJECT_ID=
# NEST_CLIENT_ID=
# NEST_CLIENT_SECRET=
# NEST_REFRESH_TOKEN=
# KASA_USERNAME=your_tp_link_email@example.com
# KASA_PASSWORD=your_tp_link_password

# --- Telegram (corrections from your phone) -------------------------------
# Create bot: Telegram → @BotFather → /newbot → copy token below.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your numeric chat id (message your bot, then open getUpdates).
TELEGRAM_ALLOWED_CHAT_IDS=your_telegram_chat_id_here

# Set to 1 when token + chat id are filled in.
TELEGRAM_ENABLED=0

# --- OpenAI (natural language → work / sleep / gaming / relaxing / away) ---
OPENAI_API_KEY=your_openai_api_key_here

# Optional model for Telegram text → label mapping.
OPENAI_MODEL=gpt-4o-mini
