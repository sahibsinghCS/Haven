API_HOST=127.0.0.1
API_PORT=8000

# Live demo from repo root: npm run demo  (see docs/DEMO.md)
ROOMOS_CONFIG=configs/inference.yaml
ROOMOS_ACTIONS_CONFIG=configs/actions.yaml
ROOMOS_LOG_LEVEL=INFO
ROOMOS_AUTOSTART=1

# Deterministic presentation (no camera/model): npm run demo:replay
# ROOMOS_DEMO_MODE=replay
# ROOMOS_DEMO_FIXTURE=configs/demo_replay.json

# Real automations (opt-in): see docs/AUTOMATION.md
# ROOMOS_ACTIONS_CONFIG=configs/actions.demo-local.yaml
# HOME_ASSISTANT_TOKEN=your_long_lived_token

# --- Telegram (corrections from your phone) -------------------------------
# Create bot: Telegram → @BotFather → /newbot → copy token below.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your numeric chat id (message your bot, then open getUpdates).
TELEGRAM_ALLOWED_CHAT_IDS=your_telegram_chat_id_here

# Set to 1 when token + chat id are filled in.
TELEGRAM_ENABLED=0

# --- OpenAI (natural language → work / sleep / gaming / relaxing / away) ---
OPENAI_API_KEY=your_openai_api_key_here

# Optional model for Telegram text → label mapping.
OPENAI_MODEL=gpt-4o-mini
