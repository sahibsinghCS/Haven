{
  "name": "room-os",
  "private": true,
  "scripts": {
    "demo": "node scripts/demo.mjs",
    "demo:replay": "node scripts/demo-replay.mjs",
    "demo:receiver": "node scripts/run-python.mjs scripts/demo_action_receiver.py",
    "setup": "node scripts/setup.mjs",
    "setup:venv": "node scripts/ensure-venv.mjs",
    "setup:install": "node scripts/setup.mjs --install-deps",
    "setup:model": "node scripts/ensure-venv.mjs && node scripts/run-python.mjs scripts/train_roomos.py demo",
    "setup:shipped-model": "node scripts/setup-shipped-model.mjs",
    "preflight": "node scripts/preflight.mjs",
    "preflight:py": "node scripts/run-python.mjs scripts/demo_preflight.py",
    "probe:cameras": "node scripts/run-python.mjs scripts/probe_cameras.py",
    "kasa:probe": "node scripts/run-python.mjs scripts/kasa_probe.py --discover",
    "kasa:on": "node scripts/run-python.mjs scripts/kasa_probe.py --on",
    "kasa:off": "node scripts/run-python.mjs scripts/kasa_probe.py --off",
    "dev": "npm run dev:stack",
    "dev:stack": "concurrently -q -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "supabase:migrate": "node scripts/run-python.mjs scripts/apply_supabase_migrations.py",
    "dev:web": "npm run dev --prefix web",
    "dev:api": "node scripts/run-uvicorn.mjs",
    "python": "node scripts/run-python.mjs",
    "py": "node scripts/run-python.mjs",
    "pytest": "node scripts/run-python.mjs -m pytest",
    "test:backend": "node scripts/run-python.mjs -m pytest -q",
    "bootstrap:demo": "npm run setup:model",
    "train:demo": "node scripts/run-python.mjs scripts/train_roomos.py demo",
    "train:images": "node scripts/run-python.mjs scripts/train_roomos.py images",
    "train:my-room": "node scripts/run-python.mjs scripts/train_my_room.py",
    "train:videos": "node scripts/run-python.mjs scripts/train_roomos.py videos",
    "train:multi-room": "node scripts/run-python.mjs scripts/train_multi_room.py --min-test-accuracy 0.78",
    "train:multi-room-v2": "node scripts/run-python.mjs scripts/train_multi_room.py -c configs/train_multi_room_v2.yaml --features-out data/features/multi_room_features_v2.csv --min-test-accuracy 0.78",
    "train:boost-work": "node scripts/run-python.mjs scripts/expand_base_images.py --target-per-class 550 --labels work",
    "train:multi-room-v3": "node scripts/run-python.mjs scripts/train_multi_room.py -c configs/train_multi_room_v3.yaml --features-out data/features/multi_room_features_v3.csv --from-features --min-test-accuracy 0.69",
    "train:expand-augs": "node scripts/run-python.mjs scripts/expand_base_images.py --target-per-class 350",
    "train:verify": "node scripts/run-python.mjs scripts/verify_bundle.py",
    "train:reinforce": "node scripts/run-python.mjs scripts/retrain_with_corrections.py",
    "feedback:clear": "node scripts/run-python.mjs scripts/clear_feedback_memory.py",
    "eval:report": "node scripts/run-python.mjs scripts/generate_eval_report.py",
    "train:layout": "node scripts/run-python.mjs scripts/train_roomos.py layout",
    "import:base-images": "node scripts/run-python.mjs scripts/import_base_images.py",
    "capture": "node scripts/run-python.mjs scripts/capture_video.py",
    "data:init": "node scripts/run-python.mjs scripts/data_collect.py init",
    "data:plan": "node scripts/run-python.mjs scripts/data_collect.py plan",
    "data:audit": "node scripts/run-python.mjs scripts/audit_dataset.py",
    "data:open-images": "node scripts/open-data-folder.mjs base",
    "data:open-personal": "node scripts/open-data-folder.mjs personal",
    "data:capture-stills": "node scripts/run-python.mjs scripts/capture_stills.py",
    "data:capture-away": "node scripts/run-python.mjs scripts/capture_stills.py --class away --count 60",
    "data:import-away": "node scripts/run-python.mjs scripts/import_base_images.py --per-class 400 --labels away",
    "data:import-sleep-bed": "node scripts/run-python.mjs scripts/import_sleep_bed.py --target-add 200",
    "data:reset-sleep": "node scripts/run-python.mjs scripts/reset_sleep_folder.py --include-raw-images",
    "datasets:check": "bash scripts/check_environment.sh",
    "datasets:download": "bash scripts/download_datasets.sh",
    "datasets:prepare": "python scripts/prepare_roomos_dataset.py",
    "datasets:ingest": "node scripts/run-python.mjs scripts/ingest_external_datasets.py --max-per-class 200 --datasets all",
    "datasets:ingest-mpii": "node scripts/run-python.mjs scripts/ingest_mpii_fiftyone.py --max-per-class 300",
    "data:capture-commands": "node scripts/run-python.mjs scripts/print_capture_commands.py",
    "build": "npm run build --prefix web",
    "lint": "npm run lint --prefix web"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
